{
  "name": "{{AGENT_NAME}}",
  "description": "{{AGENT_DESCRIPTION}}",
  "prompt": "{{AGENT_PROMPT}}",
  {{#if MCP_AMAZON_Q_HISTORY}}
  "mcpServers": {
    {{#if MCP_AMAZON_Q_HISTORY}}
    "amazon-q-history": {
      "type": "stdio",
      "command": "node",
      "args": ["{{MCP_SERVERS_PATH}}/amazon-q-history/server.js"]
    }{{#if MCP_GPT}},{{/if}}
    {{/if}}
    {{#if MCP_GPT}}
    "gpt": {
      "type": "stdio",
      "command": "node",
      "args": ["{{MCP_SERVERS_PATH}}/gpt/server.js"]
    }{{#if MCP_WEB_SCRAPER}},{{/if}}
    {{/if}}
    {{#if MCP_WEB_SCRAPER}}
    "web-scraper": {
      "type": "stdio",
      "command": "node",
      "args": ["{{MCP_SERVERS_PATH}}/web-scraper/server.js"]
    }{{#if MCP_CYPRESS}},{{/if}}
    {{/if}}
    {{#if MCP_CYPRESS}}
    "cypress": {
      "type": "stdio",
      "command": "node",
      "args": ["{{MCP_SERVERS_PATH}}/cypress/server.js"]
    }{{#if MCP_CHAKRA_UI}},{{/if}}
    {{/if}}
    {{#if MCP_CHAKRA_UI}}
    "chakra-ui": {
      "type": "stdio",
      "command": "node",
      "args": ["{{MCP_SERVERS_PATH}}/chakra-ui/server.js"]
    }
    {{/if}}
  },
  {{/if}}
  "tools": ["*"],
  "allowedTools": [
    {{#if MCP_AMAZON_Q_HISTORY}}"@amazon-q-history/*",{{/if}}
    {{#if MCP_GPT}}"@gpt/*",{{/if}}
    {{#if MCP_WEB_SCRAPER}}"@web-scraper/*",{{/if}}
    {{#if MCP_CYPRESS}}"@cypress/*",{{/if}}
    {{#if MCP_CHAKRA_UI}}"@chakra-ui/*",{{/if}}
    "web_fetch"
  ],
  "resources": ["file://{{RULES_PATH}}/*.md"],
  "toolsSettings": {
    "fs_read": {
      "allowedPaths": [
        "./**/*.json",
        "./**/*.md",
        "./**/*.yml",
        "./**/*.yaml",
        "./.gitignore"
        {{#if TYPESCRIPT}},"./**/*.ts", "./**/*.tsx"{{/if}}
        {{#if JAVASCRIPT}},"./**/*.js", "./**/*.jsx"{{/if}}
        {{#if PYTHON}},"./**/*.py"{{/if}}
        {{#if LUA}},"./**/*.lua"{{/if}}
        {{#if USE_ENV_VARS}}{{#if ENV_PROD_PROTECTION}},
        "./**/*.env.dev",
        "./**/*.env.qa",
        "./**/dev.env",
        "./**/qa.env",
        "./**/.env.example"{{/if}}{{/if}}
      ],
      "deniedPaths": [
        "./**/node_modules/",
        "./**/node_modules/**"
        {{#if USE_ENV_VARS}}{{#if ENV_PROD_PROTECTION}},
        "./**/.env",
        "./**/.env.prod",
        "./**/.env.production",
        "./**/prod.env",
        "./**/production.env"{{/if}}{{/if}}
      ]
    },
    "fs_write": {
      "allowedPaths": [
        "./**/*.json",
        "./**/*.md",
        "./**/*.yml",
        "./**/*.yaml",
        "./.gitignore"
        {{#if TYPESCRIPT}},"./**/*.ts", "./**/*.tsx"{{/if}}
        {{#if JAVASCRIPT}},"./**/*.js", "./**/*.jsx"{{/if}}
        {{#if PYTHON}},"./**/*.py"{{/if}}
        {{#if LUA}},"./**/*.lua"{{/if}}
        {{#if USE_ENV_VARS}}{{#if ENV_PROD_PROTECTION}},
        "./**/*.env.dev",
        "./**/*.env.qa",
        "./**/dev.env",
        "./**/qa.env",
        "./**/.env.example"{{/if}}{{/if}}
      ],
      "deniedPaths": [
        "./**/node_modules/",
        "./**/node_modules/**"
        {{#if USE_ENV_VARS}}{{#if ENV_PROD_PROTECTION}},
        "./**/.env",
        "./**/.env.prod",
        "./**/.env.production",
        "./**/prod.env",
        "./**/production.env"{{/if}}{{/if}}
      ]
    },
    "execute_bash": {
      "allowedCommands": [
        "ls -la*",
        "pwd",
        "find*"
        {{#if USE_GIT}},
        "git status",
        "git fetch",
        "git diff*",
        "git log*"{{/if}}
        {{#if PACKAGE_MANAGER_NPM}},
        "npm install",
        "npm test*"{{/if}}
        {{#if PACKAGE_MANAGER_YARN}},
        "yarn*"{{/if}}
        {{#if PACKAGE_MANAGER_PNPM}},
        "pnpm*"{{/if}}
        {{#if TYPESCRIPT}},
        "npx tsc --noEmit"{{/if}}
      ],
      "deniedCommands": [
        "rm -rf *",
        "sudo *",
        "chmod 777 *",
        "*--force*"
      ]
    }
  }
}
