{
  "storage_mode": "project",
  "session_ttl_hours": 0,
  "prefer_recent_session": true,
  "restore_latest": true,
  "allowed_paths": [
    "."
  ],
  "tools": {
    "mode": "allow",
    "list": [
      "track_session",
      "log_prompt",
      "log_action",
      "log_git_commits",
      "get_recent_context",
      "get_session_history",
      "check_progress",
      "close_session",
      "switch_session",
      "list_sessions",
      "restore_latest",
      "init_presession",
      "restore_backup"
    ]
  }
}
