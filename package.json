{
  "name": "cairel",
  "version": "2.2.0",
  "description": "CLI tool for generating cross-platform Agent Skills for Kiro, GitHub Copilot, Claude Code, and Amazon Q Developer",
  "main": "dist/index.js",
  "bin": {
    "cairel": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "generate-manifest": "node scripts/generate-manifest.js",
    "prebuild": "npm run generate-manifest",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "ai",
    "cli",
    "development",
    "kiro-cli",
    "amazon-q",
    "agent",
    "rules",
    "mcp"
  ],
  "author": "JMRMEDEV",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JMRMEDEV/cairel-cli.git"
  },
  "bugs": {
    "url": "https://github.com/JMRMEDEV/cairel-cli/issues"
  },
  "homepage": "https://github.com/JMRMEDEV/cairel-cli#readme",
  "files": [
    "dist",
    "curated-presets",
    ".ai",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.2",
    "ajv": "^8.17.1",
    "chalk": "^4.1.2",
    "commander": "^14.0.2",
    "fs-extra": "^11.3.3",
    "glob": "^13.0.0",
    "gray-matter": "^4.0.3",
    "handlebars": "^4.7.8",
    "ora": "5.4.1",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/glob": "^8.1.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.8",
    "jest": "^30.2.0",
    "js-yaml": "^4.1.1",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}
