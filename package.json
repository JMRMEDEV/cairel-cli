{
  "name": "cairel",
  "version": "1.0.0",
  "description": "CLI tool for initializing AI-driven development projects with standardized rules and agent configurations",
  "main": "dist/index.js",
  "bin": {
    "cairel": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "generate-manifest": "node scripts/generate-manifest.js",
    "prebuild": "npm run generate-manifest",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "ai",
    "cli",
    "development",
    "kiro-cli",
    "amazon-q",
    "agent",
    "rules",
    "mcp"
